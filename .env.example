# ═══════════════════════════════════════════════════
# 아날로그 홀리데이 — 환경변수 목록
# 실제 값은 Vercel 대시보드(Settings → Environment Variables)에 설정하세요.
# ⚠️ 이 파일에는 절대 실제 키를 넣지 마세요 (커밋되는 파일입니다).
# ═══════════════════════════════════════════════════

# ── AI (필수) ──
# Google AI Studio(https://aistudio.google.com/apikey)에서 발급
GEMINI_API_KEY=your-gemini-api-key

# ── 데이터베이스 (권장) ──
# Postgres 연결 문자열 (Neon/Supabase/Vercel Postgres 등)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# POSTGRES_URL=            # DATABASE_URL 대신 사용 가능 (동일 역할)

# ── Vercel Blob (재고 저장소) ──
BLOB_READ_WRITE_TOKEN=vercel_blob_read_write_token
BLOB_STORE_ACCESS=public

# ── 관리자 인증 (필수) ──
# admin.html / geo.html / noah.html / alex.html 로그인에 사용하는 키
RESERVATION_ADMIN_KEY=change-this-admin-key

# ── Vercel Cron 인증 (필수) ──
# vercel.json 크론이 Authorization: Bearer 헤더로 전송하는 시크릿
CRON_SECRET=change-this-cron-secret

# ── 이메일 알림 (Resend) ──
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM=Analog Holiday <hello@mg.yourdomain.com>
RESERVATION_NOTIFY_TO=owner@example.com

# ── Discord 웹훅 (에이전트 보고 채널) ──
# Discord 채널 설정 → 연동 → 웹훅 에서 생성
DISCORD_WEBHOOK_LINA=     # 리나: 신규 예약 접수 알림 (api/chat.js)
DISCORD_WEBHOOK_GIO=      # 지오: 모닝 브리핑 + 운송장 보고 (api/geo.js, cron/daily-report.js)
DISCORD_WEBHOOK_HANI=     # 하니: 저녁 매거진 + 주간 회고 (cron/evening-report.js, weekly-reflection.js)
DISCORD_WEBHOOK_STUDY=    # 자율학습 결과 보고 (api/_lib/autonomous-study.js)

# ── 기타 (선택) ──
# BRAIN_ROOT=              # 에이전트 MD Vault 저장 경로 커스텀 (기본: _brain/ 또는 /tmp/_brain)
